<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Network — WebSocket to tui_gateway, LLM API calls -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Foreground Service — keeps Hermes gateway alive (ADR-004) -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MESSAGE_INACTIVE" />

    <!-- Notifications — tool approval, gateway status (ADR-003) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Boot — auto-start gateway on device boot (temporary, ADR-004) -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- Battery — request exemption from battery optimization (ADR-004, RISK-001) -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />

    <!-- Wake lock — keep CPU awake during long tool execution -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- Vibrate — notification feedback for tool approvals -->
    <uses-permission android:name="android.permission.VIBRATE" />

    <application
        android:name=".HermesApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:usesCleartextTraffic="true"
        android:theme="@style/Theme.Hermes2"
        android:enableOnBackInvokedCallback="true"
        tools:targetApi="33">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.Hermes2"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- Share intent: receive text/plain from other apps -->
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="text/plain" />
            </intent-filter>
        </activity>

        <!-- Gateway Foreground Service (ADR-004) -->
        <service
            android:name=".service.HermesGatewayService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

        <!-- Boot Receiver (ADR-004, temporary during migration) -->
        <receiver
            android:name=".service.BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

        <!-- Approval Action Receiver (ADR-003) -->
        <receiver
            android:name=".service.ApprovalActionReceiver"
            android:exported="false" />

        <!-- WorkManager initialization — custom Configuration via Hilt -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="androidx.work.WorkManagerInitializer"
                android:value="androidx.startup"
                tools:node="remove" />
        </provider>

    </application>

</manifest>
